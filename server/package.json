{
  "name": "server",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && node -e \"const fs=require('fs'),path=require('path');fs.mkdirSync(path.join('dist','db'),{recursive:true});fs.copyFileSync(path.join('src','db','schema.sql'),path.join('dist','db','schema.sql'))\"",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "express": "^4.21.0",
    "cors": "^2.8.5",
    "sql.js": "^1.11.0",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "multer": "^1.4.5-lts.1",
    "pdfkit": "^0.15.0",
    "nodemailer": "^6.9.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "@types/express": "^5.0.0",
    "@types/cors": "^2.8.17",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/bcryptjs": "^2.4.6",
    "@types/multer": "^1.4.12",
    "@types/pdfkit": "^0.13.5",
    "@types/nodemailer": "^6.4.16",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.0"
  }
}
